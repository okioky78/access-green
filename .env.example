# 앱 origin: OAuth 리다이렉트와 POST 요청 출처 검증에 사용
APP_ORIGIN=http://localhost:8888

# 합격증 정보 추출에 사용할 서버 전용 Gemini API 키
GEMINI_API_KEY=your-gemini-api-key

# 합격증 원본 이미지가 저장될 Google Drive 폴더 ID
GOOGLE_ADMISSION_CERTIFICATE_IMAGE_FOLDER_ID=your-admission-certificate-image-folder-id

# 합격자 정보가 저장될 Google Sheet ID
GOOGLE_ADMITTED_APPLICANTS_SPREADSHEET_ID=your-admitted-applicants-spreadsheet-id

# 합격자 정보가 저장될 Google Sheet range. 비우면 서버 기본값(Sheet1!A:G) 사용
GOOGLE_ADMITTED_APPLICANTS_SHEET_RANGE=Sheet1!A:G

# Google OAuth 설정
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8888/api/google-auth-callback
GOOGLE_OAUTH_COOKIE_SECRET=replace-with-random-secret-from-openssl-rand-base64-32

# 브라우저 상단 헤더에 표시할 Google Sheet 바로가기 ID
VITE_GOOGLE_ADMITTED_APPLICANTS_SPREADSHEET_ID=your-admitted-applicants-spreadsheet-id
